{
  "name": "general-store-automation",
  "version": "1.0.0",
  "description": "Mobile automation assessment - General Store App (Appium + Playwright + TypeScript + Mocha)",
  "scripts": {
    "test:mobile": "wdio run ./src/config/wdio.conf.ts",
    "test:api": "npx playwright test --config=./src/api-tests/playwright.config.ts",
    "test:all": "npm run test:mobile && npm run test:api"
  },
  
  "devDependencies": {
    "@wdio/cli": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "@wdio/allure-reporter": "^9.0.0",
    "@wdio/types": "^9.0.0",
    "@types/mocha": "^10.0.0",
    "appium": "^2.11.0",
    "appium-uiautomator2-driver": "^3.8.0",
    "typescript": "^5.0.0",
    "tsx": "^4.0.0",
    "@playwright/test": "^1.40.0",
    "dotenv": "^16.0.0"
  }
}
